# Turso (cloud SQLite) — create a free database at https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-at-least-32-random-characters

# Super-admin seed password (must meet strength: 10+ chars, upper, lower, number, symbol)
SUPER_ADMIN_INITIAL_PASSWORD=Change_Me_Now1!

# CORS — set to your Netlify site URL in production
CORS_ORIGIN=https://your-site.netlify.app

NODE_ENV=production
